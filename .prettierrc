{
  "plugins": [
    "prettier-plugin-blade"
  ],

  "printWidth": 80,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 4,

  "overrides": [
    {
      "files": [
        "*.blade.php"
      ],
      "options": {
        "parser": "blade",
        "printWidth": 100
      }
    },
    {
      "files": [
        "*.js"
      ],
      "options": {
        "printWidth": 100
      }
    }
  ]
}
